{
  "name": "@iscn/core",
  "version": "0.1.0",
  "description": "ISCN 2024 karyotype validation — parser, rule engine, and types. Pure TypeScript, zero runtime dependencies.",
  "license": "MIT",
  "author": "Paulo Nuin",
  "homepage": "https://github.com/nuin/iscn-authenticator#readme",
  "bugs": {
    "url": "https://github.com/nuin/iscn-authenticator/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "data/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "deno test --allow-read tests/fixtures.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuin/iscn-authenticator.git",
    "directory": "packages/core"
  },
  "keywords": [
    "iscn",
    "iscn-2024",
    "karyotype",
    "cytogenetics",
    "cytogenomics",
    "bioinformatics",
    "validation",
    "nomenclature"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
